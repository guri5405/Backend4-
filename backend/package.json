{
  "name": "employee-leave-management-system",
  "version": "1.0.0",
  "description": "REST API for Employee Leave Management built with Node.js, Express, TypeScript and Supabase",
  "main": "dist/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon -r tsconfig-paths/register --exec ts-node src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "express",
    "typescript",
    "supabase",
    "leave-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "winston": "^3.17.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
